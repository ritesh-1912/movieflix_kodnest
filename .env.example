VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Aiven PostgreSQL (for auth). Used by Express server locally and by Vercel API routes when deployed.
# On Vercel: set DATABASE_URL in Project → Settings → Environment Variables.
DATABASE_URL=postgres://avnadmin:YOUR_PASSWORD@pg-xxx.aivencloud.com:11092/defaultdb?sslmode=require
